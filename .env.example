# Copy to .env and fill in. .env is gitignored.

# Anthropic — primary LLM (Claude Sonnet 4.6 for the agent, Haiku 4.5 for cheap subtasks).
ANTHROPIC_API_KEY=

# Voyage — embeddings (voyage-finance-2 likely).
VOYAGE_API_KEY=

# Cohere — reranker (optional in v1, used in ablations).
COHERE_API_KEY=

# FinancialModelingPrep — structured financial data tool. See ADR-001.
FMP_API_KEY=

# OpenAI — used only as a comparison point in ablations.
OPENAI_API_KEY=

# edgartools — SEC requires identifying your traffic; format "Your Name <your.email@example.com>".
EDGAR_IDENTITY=

# Langfuse — LLM tracing/observability (optional). If the keys are blank, tracing
# is silently skipped and the agent runs unchanged. LANGFUSE_BASE_URL is the
# region host Langfuse hands you (US: https://us.cloud.langfuse.com,
# EU: https://cloud.langfuse.com, or your self-hosted URL).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
